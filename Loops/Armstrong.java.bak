class Armstrong
{
	public static void main(String args[])
	{
		int num=153;
		int ct=0;
		
		for(int i=num;i!=0;i/=10)    //count digits
		{
			ct++;                                                          //workflow logic
		}                                                      
		int sum=0;                                                        //count digit
		                                                                 // extract digit
		while(num!=0)                                                   // raise to power
		{                                                              //  add to sum                                       
			int last=num%10;                                          //compare with number                                      
			int pow=1;
			
			for(int i=0;i<ct;i++)
			{
				pow=pow*last;
			}
				sum=sum+pow;   //add power
				
				num/=10;     //remove digit
			}
			if(sum==num)
			{
				System.out.println("It is Armstrong number");
			}
			else
			{
				System.out.println("It is not Armstrong number");
				
			}
		}
}